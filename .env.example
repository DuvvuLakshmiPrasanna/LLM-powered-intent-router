# ============================================================
# LLM Provider Configuration
# ============================================================
# Supports OpenAI, Google Gemini, or any OpenAI-compatible API.
#
# --- Option A: OpenAI ---
# OPENAI_API_KEY=sk-your-openai-api-key-here
# CLASSIFIER_MODEL=gpt-4o-mini
# GENERATION_MODEL=gpt-4o-mini
#
# --- Option B: Google Gemini (FREE tier) ---
# Get a free key at: https://aistudio.google.com/apikey
# OPENAI_API_KEY=your-gemini-api-key-here
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# CLASSIFIER_MODEL=gemini-2.5-flash
# GENERATION_MODEL=gemini-2.5-flash
# ============================================================

# API Key (required)
# ============================================================
# LLM Intent Router — Environment Configuration
# ============================================================

# --- Option A: OpenAI ---
# OPENAI_API_KEY=sk-your-openai-key-here
# CLASSIFIER_MODEL=gpt-4o-mini
# GENERATION_MODEL=gpt-4o-mini

# --- Option B: Google Gemini (FREE tier) ---
# Get a free key at: https://aistudio.google.com/apikey
# OPENAI_API_KEY=your-gemini-api-key-here
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# CLASSIFIER_MODEL=gemini-2.5-flash
# GENERATION_MODEL=gemini-2.5-flash

# ============================================================
# Required
# ============================================================
OPENAI_API_KEY=your-api-key-here

# Optional: Base URL for OpenAI-compatible providers
# OPENAI_BASE_URL=

# Server port (default: 3000)
PORT=3000

# Models (default: gpt-4o-mini)
CLASSIFIER_MODEL=gpt-4o-mini
GENERATION_MODEL=gpt-4o-mini

# Confidence threshold (0.0-1.0). Below this → unclear (default: 0.7)
CONFIDENCE_THRESHOLD=0.7
